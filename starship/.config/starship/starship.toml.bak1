format = """
$directory\
$git_branch\
$git_status\
$character
"""

add_newline = false 

[character]
success_symbol = '[➜](bold green)'
error_symbol = '[➜](bold red)'
vimcmd_symbol = '[➜](bold blue)'

[directory]
truncation_length = 1 
fish_style_pwd_dir_length = 1
truncate_to_repo = false
style = "bold cyan"
